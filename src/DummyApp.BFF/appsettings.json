{
  "Authentication": {
    "Oidc": {
      "Authority": "https://localhost:5005",
      "ClientId": "dummyapp.bff",
      "ClientSecret": "secret"
    }
  },

  "ReverseProxy": {
    "Routes": {
      "api_route": {
        "ClusterId": "api_cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      }
    },
    "Clusters": {
      "api_cluster": {
        "Destinations": {
          "api1": {
            "Address": "https://localhost:6001/"
          }
        }
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
